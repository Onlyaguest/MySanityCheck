{:paths ["src"]
 :pods {org.babashka/go-sqlite3 {:version "0.3.1"}}
 :deps {cheshire/cheshire {:mvn/version "5.12.0"}}
 :tasks
 {:requires ([ems.core :as core])
  
  run   {:doc "Start EMS daemon"
         :task (core/start!)}
  
  init  {:doc "Initialize database"
         :task (do (require 'ems.db) ((resolve 'ems.db/init!)))}}}
